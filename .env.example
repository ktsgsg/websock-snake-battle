# Cloudflare Tunnel token
# Dashboard: https://one.dash.cloudflare.com/ → Networks → Tunnels → Create a tunnel
# Tunnel の Public Hostname に http://client:80 を指定してください
TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# --- Game parameters (all optional; defaults shown) ---
# Server tick interval in milliseconds. Smaller = faster game.
GAME_TICK_MS=120
# Grid size (cells)
GAME_GRID_W=40
GAME_GRID_H=30
# Maximum players per room (1-4 recommended; affects color palette)
GAME_MAX_PLAYERS=4
# Initial snake length in segments
GAME_INITIAL_LENGTH=3
# Match time limit in seconds. 0 = unlimited.
# On timeout, the longest surviving snake wins (Draw if tied).
GAME_TIME_LIMIT_SEC=0
# Goal snake length. First snake to reach this length wins. 0 = disabled.
GAME_GOAL_LENGTH=0
# Ticks before a dropped bomb detonates.
GAME_BOMB_FUSE_TICKS=3
# Cross-shaped explosion reach (cells in each of 4 directions).
GAME_BOMB_RANGE=3
# Probability that a newly spawned food is blue (bomb). 0.0–1.0.
GAME_BOMB_FOOD_CHANCE=0.25
# Countdown seconds shown before the match actually starts. 0 = skip.
GAME_COUNTDOWN_SEC=3
# SQLite file path used to persist room codes across temporary disconnects.
GAME_ROOM_DB_PATH=data/rooms.sqlite
